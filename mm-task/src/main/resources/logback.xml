<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--控制台-->
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>[%d{yyyy-MM-dd HH:mm:ss}] %p [ %thread] %c{50}:%L - %m%n</pattern>
            <charset class="java.nio.charset.Charset">UTF-8</charset>
        </encoder>
    </appender>
    <!--file append-->
    <appender name="file" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <File>logs/msg-task.log</File>
        <Append>true</Append>
        <encoder>
            <pattern>[%d{yyyy-MM-dd HH:mm:ss}] %p [ %thread] %c{1}:%L - %m%n</pattern>
            <charset class="java.nio.charset.Charset">UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/msg-task.log.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 每个文件最大 500M ，最多保留10天，但是总的大小不超过2G -->
            <maxFileSize>500MB</maxFileSize>
            <maxHistory>10</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <logger name="org.springframework" level="WARN" />
    <logger name="org.springframework.data.mongodb" level="DEBUG" />
    <logger name="org.mongodb.driver" level="INFO" />
    <logger name="org.springframework.data.mongodb.core.MongoDbUtils" level="DEBUG" />
    <logger name="com.fanggeek.msg" level="DEBUG" />

    <root level="debug">
        <appender-ref ref="console" />
        <appender-ref ref="file" />
    </root>
</configuration>